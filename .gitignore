# Ignore everything
*

# Except the scripts directory
!scripts/
!scripts/**

# ...but not compiled TMB artifacts within it (platform-specific, rebuilt via TMB::compile())
scripts/*.o
scripts/*.so

# And the top-level README and .gitignore itself
!README.md
!.gitignore


# Top-level non-script files
analysis/
birds_SR.tif
birds_SUM_RSR.tif
checks/
data/
expert_ranges/
figures/
jobs/
log/
raw_data/
res/
trees/
*.RData
*.Rdata
*.rds
*.tif
.DS_Store